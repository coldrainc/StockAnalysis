# Chat model provider. Codex config is also read by default.
# OpenAI-compatible providers are supported. Set STOCK_MODEL_PROVIDER=deepseek
# to use DeepSeek with DEEPSEEK_API_KEY.
STOCK_MODEL_PROVIDER=openai
STOCK_MODEL=
STOCK_MODEL_BASE_URL=
STOCK_MODEL_API_KEY_ENV=
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
GATEWAY_API_KEY=

# RAG / vector store
STOCK_VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=stock_agent

# Embedding
EMBEDDING_PROVIDER=service
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_SERVICE_URL=http://127.0.0.1:8010

# Paths
STOCK_KNOWLEDGE_BASE=knowledge_base/stock_universe
STOCK_RAG_INDEX=.stock_agent/rag_index.json
STOCK_RAG_VECTORS=.stock_agent/rag_vectors.json
STOCK_VECTOR_STORE_METADATA=.stock_agent/vector_store.json
STOCK_MEMORY_PATH=.stock_agent/memory

# Optional dynamic data providers.
# These endpoints are expected to return JSON and are called with ticker/name params.
STOCK_ANNOUNCEMENT_API_URL=
STOCK_FINANCIALS_API_URL=

# Retrieval
RAG_TOP_K=4
RAG_MAX_CHARS=6000
